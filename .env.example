# homelab-registry-mcp — environment configuration
#
# Minimum viable config (get started in 5 minutes):
#   TRAEFIK_API_URL, AUTHENTIK_API_URL, AUTHENTIK_TOKEN
#   Everything else has sensible defaults.
#
# Read operations are always on when the upstream is configured.
# Write operations (proposals, normalization) are opt-in — off by default.
# See docs/agentic-design-intent.md for the full design rationale.

# -----------------------------------------------------------------------------
# Persistence
# Both paths should use /data/ to stay on the named Docker volume.
# Using ./data/ (relative) resolves to /app/data/ inside the container —
# a different location that does not persist across rebuilds.
# -----------------------------------------------------------------------------
REGISTRY_DB_PATH=/data/registry.db
REGISTRY_LOG_PATH=/data/events.log
EVENT_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# MCP transport
# streamable-http is recommended for multi-client homelab use.
# Use stdio only for local development or single-client setups.
# -----------------------------------------------------------------------------
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8765

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Traefik integration (read-only)
# Required for discovery, router inspection, and conflict detection.
# -----------------------------------------------------------------------------
TRAEFIK_API_URL=http://<WORKLOAD_NODE_IP>:8080
TRAEFIK_TIMEOUT_SECONDS=10
TRAEFIK_RETRIES=3

# -----------------------------------------------------------------------------
# Authentik integration (read-only)
# Token MUST be a scoped read-only service account. Never use an admin token.
# Required permissions: view on applications, providers, outposts, policies,
# events, users, groups.
# -----------------------------------------------------------------------------
AUTHENTIK_API_URL=https://sso.yourdomain.com/api/v3
AUTHENTIK_TOKEN=
AUTHENTIK_TIMEOUT_SECONDS=10
AUTHENTIK_RETRIES=3

# -----------------------------------------------------------------------------
# Docker integration (read-only)
# Enables container-level discovery alongside Traefik router discovery.
# Remove or leave blank to disable Docker discovery.
# -----------------------------------------------------------------------------
DOCKER_BASE_URL=unix:///var/run/docker.sock

# -----------------------------------------------------------------------------
# Discovery scheduler
# A source is only enabled when its upstream is configured above.
# Intervals are in seconds.
# -----------------------------------------------------------------------------
DISCOVERY_TRAEFIK_INTERVAL_SECONDS=300
DISCOVERY_DOCKER_INTERVAL_SECONDS=300
DISCOVERY_AUTHENTIK_INTERVAL_SECONDS=900
DISCOVERY_STALE_AFTER_MISSES=3

# -----------------------------------------------------------------------------
# Reasoning layer — DSPy enrichment (Phase 7, opt-in)
# When enabled, the server uses LLM reasoning to:
#   - resolve fuzzy cross-source matches the deterministic rules miss
#     (ResolveServiceIdentity)
#   - infer display_name/category/auth_mode/notes for new Traefik-only services
#     (InferServiceMetadata)
#   - back the authentik_summarize_events tool (SummarizeAccessAudit)
#   - generate config patches for security proposals (GenerateRemediationPatch)
#   - normalize YAML formatting (NormalizeConfigFile)
# The reasoning layer never writes to infrastructure — it only enriches the
# registry, synthesizes audit summaries, and generates proposed patches.
# Output below the confidence threshold is discarded; the deterministic path
# applies for enrichment, and the proposal is rejected for patch generation.
# DSPY_MODEL is a litellm model id. DSPY_API_KEY falls back to ANTHROPIC_API_KEY.
# DSPY_COMPILED_PATH points at optimized modules saved by a Phase 9 pass.
# -----------------------------------------------------------------------------
DSPY_ENABLED=false
DSPY_MODEL=anthropic/claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=             # used by DSPy/litellm when DSPY_API_KEY is unset
# DSPY_API_KEY=                # override if you want a separate key for this server
DSPY_CONFIDENCE_THRESHOLD=0.7
DSPY_MAX_TOKENS=1024
# DSPY_PATCH_MAX_TOKENS: larger budget for GenerateRemediationPatch, which must
# emit a complete corrected file plus all output fields. Too small truncates the
# response and fails field parsing.
DSPY_PATCH_MAX_TOKENS=4096
# DSPY_COMPILED_PATH=/data/dspy   # dir of optimized modules; loaded at startup if present

# -----------------------------------------------------------------------------
# Notifications (optional)
# Used by the proposal engine to alert when PRs are opened or conflicts
# are verified. Set NOTIFICATION_PROVIDER=none to disable.
# Supported: ntfy | none
# Future: gotify | pushover | slack | discord
# -----------------------------------------------------------------------------
NOTIFICATION_PROVIDER=none
NOTIFICATION_URL=https://ntfy.yourdomain.com
NOTIFICATION_TOPIC=homelab-registry
# NOTIFICATION_TOKEN=          # Required if your Ntfy topic has auth enabled

# -----------------------------------------------------------------------------
# Git provider (required for write path / Phase 8)
# Used to open pull requests proposing infrastructure remediations.
# Token requires repo read+write scope.
# Supported: gitea | github
# Gitea and Forgejo are API-compatible — use gitea for both.
# -----------------------------------------------------------------------------
GIT_PROVIDER=github
GIT_BASE_URL=https://github.com
GIT_TOKEN=
GIT_REPO=username/homelab
GIT_BASE_BRANCH=main

# -----------------------------------------------------------------------------
# Apply mechanism
# Tells the proposal engine what instructions to put in PR descriptions.
# The MCP server never applies changes itself — it only opens PRs.
# Supported: manual | webhook | ansible
#   manual    — PR description includes manual deploy steps
#   webhook   — PR description notes a webhook triggers deployment on merge
#   ansible   — PR description notes GitHub Actions triggers Ansible on merge
# -----------------------------------------------------------------------------
APPLY_MODE=manual

# -----------------------------------------------------------------------------
# Proposal engine (write path — opt-in)
# PROPOSAL_AUTO_CREATE: when true, the scheduler automatically opens a PR
#   for each detected conflict. When false, use proposal_create() manually.
# PROPOSAL_DRY_RUN: when true, patches are generated and logged but no PRs
#   are opened. Recommended for first deployment of the write path.
# PROPOSAL_STALE_DAYS: open proposals older than this trigger a reminder
#   notification.
# PROPOSAL_CONFIDENCE_THRESHOLD: patches below this score are rejected for
#   manual review rather than committed as PRs.
# PROPOSAL_LABEL: label applied to all PRs opened by this server.
# PROPOSAL_COMPOSE_PATH_TEMPLATE: maps a service to its compose file in the
#   homelab repo. {node} and {service} are substituted at runtime.
# -----------------------------------------------------------------------------
PROPOSAL_AUTO_CREATE=false
PROPOSAL_DRY_RUN=true
PROPOSAL_STALE_DAYS=7
PROPOSAL_CONFIDENCE_THRESHOLD=0.8
PROPOSAL_LABEL=homelab-registry-mcp
PROPOSAL_COMPOSE_PATH_TEMPLATE=nodes/{node}/{service}/compose.yaml

# -----------------------------------------------------------------------------
# Normalization (opt-in)
# When enabled, the server scans compose files and Traefik dynamic configs
# for YAML formatting inconsistencies and proposes normalization PRs.
# Always separate from security proposals — never bundled.
# Only enable after the security proposal path is proven in production.
# -----------------------------------------------------------------------------
NORMALIZATION_ENABLED=false
NORMALIZATION_SCHEDULE=weekly

# -----------------------------------------------------------------------------
# Secrets / git-crypt (Phase C)
# Encrypts .env files in the private homelab repo at rest on GitHub so secrets
# are protected from day one. On by default — set SECRETS_REPO_PATH and one of
# the key options below, then run scripts/setup-homelab-repo.sh once to
# initialise the repo and export the key.
#
# Key loading priority:
#   1. SECRETS_KEY_PATH (path to the exported key file — recommended for prod)
#   2. SECRETS_GIT_CRYPT_KEY (base64-encoded key bytes — good for Docker secrets)
#
# SECRETS_REPO_PATH: path to the cloned private homelab repo on this node.
# SECRETS_KEY_PATH:  path to the git-crypt key file (chmod 400).
#   Store this key in Vaultwarden. Never commit it to any repository.
# SECRETS_GIT_CRYPT_KEY: base64(key bytes). Fallback when no key file is used.
#   Generate with: base64 /path/to/git-crypt.key | tr -d '\n'
# -----------------------------------------------------------------------------
SECRETS_ENABLED=true
SECRETS_REPO_PATH=/opt/homelab        # Pi default; use $HOME/homelab on macOS/Linux laptop
# SECRETS_KEY_PATH=/opt/homelab/.git-crypt.key   # Pi; use $HOME/.config/homelab/git-crypt.key on laptop
# SECRETS_GIT_CRYPT_KEY=
